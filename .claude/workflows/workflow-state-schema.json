{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WorkflowState",
  "description": "Schema for the agent team workflow state file. Written to .scratch/{task-slug}/workflow-state.json and updated at every phase transition.",
  "type": "object",
  "required": ["version", "feature", "state", "config", "phases", "agents", "iterations", "history"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0",
      "description": "Schema version for forward compatibility"
    },
    "feature": {
      "type": "object",
      "description": "Metadata about the task being executed",
      "required": ["name", "slug", "description", "tier"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-readable task name"
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "URL-safe slug used for the scratch directory name"
        },
        "description": {
          "type": "string",
          "description": "Full task description as provided by the user"
        },
        "tier": {
          "type": "integer",
          "enum": [1, 2, 3],
          "description": "Workflow tier: 1 (Simple), 2 (Medium), 3 (Complex)"
        },
        "domains": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Logical domains this task touches (e.g., 'ui', 'api', 'database')"
        },
        "estimatedFiles": {
          "type": "integer",
          "description": "Estimated number of files to create or modify"
        }
      }
    },
    "state": {
      "type": "string",
      "enum": [
        "IDLE",
        "RESEARCH",
        "PLANNING",
        "CONSENSUS",
        "HUMAN_GATE_PLAN",
        "IMPLEMENTING",
        "VERIFYING",
        "QA",
        "HUMAN_GATE_QA",
        "FIXING",
        "COMPLETE",
        "FAILED",
        "ESCALATED"
      ],
      "description": "Current state in the workflow state machine"
    },
    "config": {
      "type": "object",
      "description": "Workflow configuration derived from the selected tier",
      "required": ["model", "humanGates", "maxFixIterations"],
      "properties": {
        "model": {
          "type": "string",
          "default": "opus",
          "description": "Model used for all agents"
        },
        "humanGates": {
          "type": "object",
          "required": ["plan", "qa"],
          "properties": {
            "plan": {
              "type": "boolean",
              "description": "Whether to pause for user approval after planning (Tier 2, 3)"
            },
            "qa": {
              "type": "boolean",
              "description": "Whether to pause for user approval after QA (Tier 3)"
            }
          }
        },
        "maxFixIterations": {
          "type": "integer",
          "default": 3,
          "description": "Maximum fix cycles before escalating to user"
        },
        "agentCounts": {
          "type": "object",
          "description": "Planned agent counts per phase",
          "properties": {
            "research": { "type": "integer" },
            "planners": { "type": "integer" },
            "implementation": { "type": "integer" },
            "verification": { "type": "integer" },
            "qa": { "type": "integer" }
          }
        }
      }
    },
    "phases": {
      "type": "object",
      "description": "Tracking for each workflow phase",
      "properties": {
        "research": {
          "$ref": "#/$defs/phaseStatus"
        },
        "planning": {
          "$ref": "#/$defs/phaseStatus"
        },
        "consensus": {
          "allOf": [{ "$ref": "#/$defs/phaseStatus" }],
          "properties": {
            "verdict": {
              "type": "string",
              "enum": ["TRUE_CONSENSUS", "NEAR_CONSENSUS", "FALSE_CONSENSUS"],
              "description": "Consensus verdict (Tier 3 only)"
            }
          }
        },
        "implementation": {
          "$ref": "#/$defs/phaseStatus"
        },
        "verification": {
          "allOf": [{ "$ref": "#/$defs/phaseStatus" }],
          "properties": {
            "checks": {
              "type": "object",
              "properties": {
                "build": { "$ref": "#/$defs/checkResult" },
                "typeCheck": { "$ref": "#/$defs/checkResult" },
                "lint": { "$ref": "#/$defs/checkResult" },
                "tests": { "$ref": "#/$defs/checkResult" },
                "debugScan": { "$ref": "#/$defs/checkResult" }
              }
            }
          }
        },
        "qa": {
          "allOf": [{ "$ref": "#/$defs/phaseStatus" }],
          "properties": {
            "verdict": {
              "type": "string",
              "enum": ["PASS", "PASS_WITH_NOTES", "FAIL"],
              "description": "Final QA verdict"
            },
            "blockCount": {
              "type": "integer",
              "description": "Number of BLOCK-severity findings"
            },
            "warnCount": {
              "type": "integer",
              "description": "Number of WARN-severity findings"
            },
            "noteCount": {
              "type": "integer",
              "description": "Number of NOTE-severity findings"
            }
          }
        }
      }
    },
    "agents": {
      "type": "object",
      "description": "Tracking for all spawned agents",
      "required": ["total", "completed", "failed", "instances"],
      "properties": {
        "total": {
          "type": "integer",
          "description": "Total agents spawned across all phases"
        },
        "completed": {
          "type": "integer",
          "description": "Agents that completed successfully"
        },
        "failed": {
          "type": "integer",
          "description": "Agents that failed or produced invalid output"
        },
        "instances": {
          "type": "array",
          "description": "Individual agent tracking records",
          "items": {
            "type": "object",
            "required": ["id", "role", "phase", "status"],
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique agent identifier (e.g., 'research-1', 'impl-3')"
              },
              "role": {
                "type": "string",
                "enum": [
                  "research",
                  "planner",
                  "auditor",
                  "implementation",
                  "verification",
                  "code-reviewer",
                  "integration-reviewer",
                  "fix-planner"
                ]
              },
              "phase": {
                "type": "string",
                "description": "Which workflow phase this agent belongs to"
              },
              "status": {
                "type": "string",
                "enum": ["RUNNING", "COMPLETED", "FAILED", "RETRIED"]
              },
              "assignedSteps": {
                "type": "array",
                "items": { "type": "integer" },
                "description": "Plan step numbers assigned to this agent (implementation agents)"
              },
              "outputFile": {
                "type": "string",
                "description": "Path to the agent's output file"
              },
              "startedAt": {
                "type": "string",
                "format": "date-time"
              },
              "completedAt": {
                "type": ["string", "null"],
                "format": "date-time"
              },
              "error": {
                "type": ["string", "null"],
                "description": "Error message if agent failed"
              }
            }
          }
        }
      }
    },
    "iterations": {
      "type": "object",
      "description": "Fix cycle tracking",
      "required": ["current", "max", "cycles"],
      "properties": {
        "current": {
          "type": "integer",
          "default": 0,
          "description": "Current fix iteration (0 = no fixes needed yet)"
        },
        "max": {
          "type": "integer",
          "default": 3,
          "description": "Maximum allowed fix iterations"
        },
        "cycles": {
          "type": "array",
          "description": "Record of each fix cycle",
          "items": {
            "type": "object",
            "required": ["iteration", "trigger", "blockItems", "status"],
            "properties": {
              "iteration": {
                "type": "integer"
              },
              "trigger": {
                "type": "string",
                "enum": ["VERIFICATION_FAIL", "QA_FAIL"],
                "description": "What triggered this fix cycle"
              },
              "blockItems": {
                "type": "array",
                "items": { "type": "string" },
                "description": "List of BLOCK items being addressed"
              },
              "fixPlanFile": {
                "type": "string",
                "description": "Path to the fix plan file"
              },
              "status": {
                "type": "string",
                "enum": ["IN_PROGRESS", "RESOLVED", "UNRESOLVED"]
              }
            }
          }
        }
      }
    },
    "history": {
      "type": "array",
      "description": "Chronological log of all state transitions",
      "items": {
        "type": "object",
        "required": ["from", "to", "timestamp", "reason"],
        "properties": {
          "from": {
            "type": "string",
            "description": "Previous state"
          },
          "to": {
            "type": "string",
            "description": "New state"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "reason": {
            "type": "string",
            "description": "Why this transition occurred"
          },
          "agentId": {
            "type": ["string", "null"],
            "description": "Agent that triggered this transition, if applicable"
          }
        }
      }
    },
    "cost": {
      "type": "object",
      "description": "Cost tracking for the workflow",
      "properties": {
        "estimatedAgents": {
          "type": "integer",
          "description": "Estimated total agents at workflow start"
        },
        "actualAgents": {
          "type": "integer",
          "description": "Actual total agents spawned (updated as workflow runs)"
        },
        "estimatedCost": {
          "type": "string",
          "description": "Estimated cost string (e.g., '~$4')"
        }
      }
    },
    "scratchDir": {
      "type": "string",
      "description": "Absolute path to the scratch workspace for this task"
    },
    "startedAt": {
      "type": "string",
      "format": "date-time",
      "description": "When the workflow was initiated"
    },
    "completedAt": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "When the workflow reached a terminal state"
    }
  },
  "$defs": {
    "phaseStatus": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["PENDING", "IN_PROGRESS", "COMPLETED", "FAILED", "SKIPPED"]
        },
        "startedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "completedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "outputFile": {
          "type": ["string", "null"],
          "description": "Path to the phase's primary output file"
        }
      }
    },
    "checkResult": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["PASS", "FAIL", "SKIPPED"]
        },
        "details": {
          "type": ["string", "null"],
          "description": "Error output or summary"
        }
      }
    }
  }
}
