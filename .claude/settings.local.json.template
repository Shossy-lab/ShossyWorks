{
  // =============================================================================
  // settings.local.json — Machine-specific MCP permissions
  // =============================================================================
  //
  // Copy this file to settings.local.json and uncomment/edit the MCP servers
  // you have configured on your machine. This file is gitignored and will NOT
  // be committed to the repository.
  //
  // Each entry grants Claude permission to use that MCP server's tools.
  // Only enable servers you have actually installed and configured.
  //
  // To find your MCP server names, check:
  //   ~/.claude/mcp-settings.json  (global MCP config)
  //   .claude/mcp-settings.json    (project-level MCP config)
  //
  // =============================================================================

  "permissions": {
    "allow": [
      // --- Common MCP Servers ---
      // Uncomment the ones you have configured:

      // "mcp__supabase__*",              // Supabase — DB, auth, edge functions
      // "mcp__claude_ai_Supabase__*",    // Supabase (Claude.ai integration)
      // "mcp__github__*",                // GitHub — repos, PRs, issues
      // "mcp__claude_ai_Versel__*",      // Vercel — deployments, projects
      // "mcp__claude_ai_Figma__*",       // Figma — design files, components
      // "mcp__claude_ai_Gmail__*",       // Gmail — email read/send
      // "mcp__claude_ai_LucidChart__*",  // LucidChart — diagrams, flowcharts
      // "mcp__claude_ai_M365__*",        // Microsoft 365 — Office, SharePoint
      // "mcp__claude_ai_Notion__*",      // Notion — pages, databases
      // "mcp__claude_ai_n8n__*",         // n8n — workflow automation
      // "mcp__azure__*",                 // Azure — cloud resources, deployments

      // --- Add your custom MCP servers below ---
      ""
    ]
  }
}
